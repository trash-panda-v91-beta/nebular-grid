#!/usr/bin/env bash
#MISE description="Render Talos config for a node"
#USAGE arg "<node>" help="Node name (e.g. aka, ao, midori)"
set -euo pipefail

TALOS_DIR="$(dirname "$0")/../../../clusters/psb/talos"

IS_CONTROLPLANE=$(minijinja-cli "${TALOS_DIR}/nodes/${usage_node}.yaml.j2" \
  | yq -e 'select(.machine) | (.machine.type == "controlplane") // ""')

export IS_CONTROLPLANE

talosctl machineconfig patch \
  <(minijinja-cli "${TALOS_DIR}/machineconfig.yaml.j2") \
  -p @<(minijinja-cli "${TALOS_DIR}/nodes/${usage_node}.yaml.j2")
